{
	"name": "sonny-x-inkfire/example-dashboard-plugin",
	"description": "React dashboard and REST API example for WordPress.",
	"type": "wordpress-plugin",
	"license": "MIT",
	"authors": [
		{
			"name": "Sonny x Inkfire"
		}
	],
	"require": {
		"php": ">=8.2"
	},
	"require-dev": {
		"10up/wp_mock": "^1.0",
		"brain/monkey": "^2.6",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpunit/phpunit": "^9.6",
		"squizlabs/php_codesniffer": "^3.10",
		"wp-coding-standards/wpcs": "^3.1"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	},
	"scripts": {
		"lint": "phpcs",
		"test": "phpunit"
	}
}
