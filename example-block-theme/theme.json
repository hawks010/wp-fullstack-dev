{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{
					"slug": "ink",
					"color": "#1d2327",
					"name": "Ink"
				},
				{
					"slug": "paper",
					"color": "#ffffff",
					"name": "Paper"
				},
				{
					"slug": "accent",
					"color": "#3858e9",
					"name": "Accent"
				}
			]
		},
		"spacing": {
			"units": [ "px", "rem", "vw" ]
		},
		"typography": {
			"fluid": true
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|paper",
			"text": "var:preset|color|ink"
		},
		"spacing": {
			"blockGap": "1.5rem"
		},
		"typography": {
			"fontFamily": "-apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var:preset|color|accent"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		}
	]
}
